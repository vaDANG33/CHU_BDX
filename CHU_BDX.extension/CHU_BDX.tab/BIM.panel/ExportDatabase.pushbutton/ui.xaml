<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sélection des Catégories à Exporter" 
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="400">
    
    <Window.Resources>
        <!-- Style pour les boutons -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Titre -->
        <TextBlock Grid.Row="0" 
                   FontSize="16" 
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Text="Sélectionnez les catégories à exporter"/>
        
        <!-- Barre de recherche -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Rechercher:" FontSize="12" Margin="0,0,0,5"/>
            <TextBox x:Name="search_box" 
                     Height="25"
                     TextChanged="search_categories"/>
        </StackPanel>
        
        <!-- Liste des catégories avec compteur -->
        <Border Grid.Row="2" 
                BorderBrush="Gray" 
                BorderThickness="1"
                Margin="0,0,0,10">
            <ListBox x:Name="category_listbox" 
                     SelectionMode="Extended"
                     SelectionChanged="update_counter">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" 
                                       FontSize="12" 
                                       Width="350"/>
                            <TextBlock Text="{Binding Count}" 
                                       FontSize="11" 
                                       Foreground="Gray"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        
        <!-- Compteur de sélection -->
        <TextBlock Grid.Row="3" 
                   x:Name="selection_counter"
                   FontSize="11"
                   Foreground="DarkBlue"
                   Margin="0,0,0,10"
                   Text="0 catégorie(s) sélectionnée(s)"/>
        
        <!-- Boutons d'action -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Tout sélectionner" 
                    Click="select_all_click"
                    Background="#E0E0E0"/>
            <Button Content="Tout désélectionner" 
                    Click="deselect_all_click"
                    Background="#E0E0E0"/>
            <Button Content="Annuler" 
                    Click="cancel_click"
                    Background="#FFE0E0"/>
            <Button Content="Exporter" 
                    Click="export_click"
                    Background="#D0FFD0"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
